# --- ElevenLabs voice agent ---
# Agent ID from the ElevenLabs dashboard (Agents -> your agent).
ELEVENLABS_AGENT_ID=
# API key: only needed if the agent is PRIVATE (backend fetches a signed URL,
# key stays server-side). Leave blank for a public agent.
ELEVENLABS_API_KEY=

# --- Answer storage ---
# Answers append to answers.jsonl next to the code. Override the path if you want.
ANSWERS_LOG=

# --- Dispense trigger ---
# Details TBD. Set the URL when you have it; blank = just log the payload.
TRIGGER_URL=
